// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  user_id Int @id @default(autoincrement())
  username String @db.VarChar(300)
  email String @db.VarChar(300) @unique
  password String @db.VarChar(16)
  createdAt DateTime @default(now())
  projects Project[]
  comments Comments[]
}


model Project {
  project_id Int @id @default(autoincrement())
  user_id Int 
  project_name String @db.VarChar(300)
  createdAt DateTime @default(now()) 
  user User @relation(fields: [user_id],references: [user_id])
  issues Issue[]
}


enum Status {
  open
  in_progress
  closed
}

model Issue {
  issue_id Int @id @default(autoincrement())
  title String @db.VarChar(300)
  project_id Int
  description String
  status Status @default(open)
  createdAt DateTime @default(now())
  project Project @relation(fields: [project_id],references: [project_id])
  issues Comments[]
}


model Comments{
  comment_id Int @id @default(autoincrement())
  issue_id Int
  user_id Int
  comment String
  created DateTime @default(now())
  user User @relation(fields: [user_id],references: [user_id])
  issue Issue @relation(fields: [issue_id],references: [issue_id])
}